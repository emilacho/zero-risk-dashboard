{
  "name": "zero-risk-dashboard",
  "private": true,
  "version": "0.1.0",
  "description": "Zero Risk · custom dashboard · Next.js 15 + Tailwind v4 + shadcn + Tremor + ReactFlow · agents x clients control surface",
  "license": "AGPL-3.0",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:check": "next lint --max-warnings=0 --quiet",
    "audit:format-prop": "node scripts/audit-format-prop.mjs",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "verify": "pnpm type-check && pnpm lint && pnpm audit:format-prop && pnpm test",
    "prepare": "husky"
  },
  "lint-staged": {
    "{components,app,lib}/**/*.{ts,tsx,js,jsx}": "next lint --file"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.47.0",
    "@tanstack/react-table": "^8.21.3",
    "@tremor/react": "^3.18.0",
    "@xyflow/react": "^12.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.469.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.76.0",
    "recharts": "^2.15.4",
    "tailwind-merge": "^2.5.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "eslint-plugin-local": "file:eslint-plugin-local",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
